{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://laserdesk.local/schemas/workflow-v1.json",
	"title": "laserDESK workflow definition",
	"description": "Workflow-driven UI: steps define visible navigation and allowed actions. Consumed by the Svelte Kit frontend.",
	"type": "object",
	"required": ["id", "version", "title", "steps"],
	"additionalProperties": false,
	"properties": {
		"id": {
			"type": "string",
			"description": "Stable workflow identifier (filename convention: kebab-case)."
		},
		"version": {
			"type": "string",
			"description": "Semantic version of the workflow document."
		},
		"title": {
			"type": "string"
		},
		"description": {
			"type": "string"
		},
		"steps": {
			"type": "array",
			"minItems": 1,
			"items": { "$ref": "#/$defs/step" }
		}
	},
	"$defs": {
		"step": {
			"type": "object",
			"required": ["id", "title", "kind"],
			"additionalProperties": false,
			"properties": {
				"id": {
					"type": "string",
					"pattern": "^[a-z][a-z0-9-]*$",
					"description": "Unique step id within the workflow."
				},
				"title": { "type": "string" },
				"description": { "type": "string" },
				"kind": {
					"type": "string",
					"enum": ["connect", "parameters", "load-job", "run", "status", "custom"]
				},
				"allowedActions": {
					"type": "array",
					"items": { "type": "string" },
					"description": "Logical action ids the UI may expose for this step (app-specific)."
				},
				"connectOptions": {
					"type": "object",
					"additionalProperties": false,
					"properties": {
						"defaultMode": {
							"type": "string",
							"enum": ["mock", "ethernet"]
						}
					}
				},
				"parameterFields": {
					"type": "array",
					"items": { "$ref": "#/$defs/parameterField" }
				}
			}
		},
		"parameterField": {
			"type": "object",
			"required": ["id", "label", "type"],
			"additionalProperties": false,
			"properties": {
				"id": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9_]*$" },
				"label": { "type": "string" },
				"type": {
					"type": "string",
					"enum": ["string", "number", "boolean", "select"]
				},
				"default": {},
				"options": {
					"type": "array",
					"items": { "type": "string" },
					"description": "For type \"select\", human-readable option labels."
				},
				"apiBinding": {
					"type": "string",
					"description": "Maps to API client field, e.g. minimalJob.label"
				}
			}
		}
	}
}
